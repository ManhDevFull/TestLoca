{
  "name": "testloc-pwa",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "build:hybrid": "CAPACITOR_BUILD=1 next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "cap:sync": "npm run build:hybrid && npx cap sync",
    "cap:sync:android": "npm run build:hybrid && npx cap sync android",
    "cap:open:android": "npx cap open android",
    "cap:run:android": "npm run cap:sync:android && npx cap run android",
    "cap:run:android:live": "npx cap run android -l --external"
  },
  "dependencies": {
    "@capacitor/core": "^8.1.0",
    "@capacitor/geolocation": "^8.1.0",
    "@capacitor/motion": "^8.0.0",
    "@ducanh2912/next-pwa": "^10.2.9",
    "cordova-plugin-device-orientation": "^3.0.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/ios": "^8.1.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "typescript": "^5"
  }
}
